{
  "version": 2,
  "public": true,
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "framework": "nextjs",
  "projectSettings": {
    "sourceFilesOutsideRootDirectory": true
  },
  "env": {
    "NODE_ENV": "production"
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/",
      "continue": true
    }
  ],
  "experimentalServices": {
    "epl-analytics": {
      "type": "web",
      "routePrefix": "/",
      "framework": "nextjs",
      "buildCommand": "npm run build"
    }
  }
}
